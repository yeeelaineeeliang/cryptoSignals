# ============================================
# Web (apps/web/.env.local)
# ============================================

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase (web uses anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ============================================
# Worker (apps/worker/.env)  --  also set in Railway dashboard
# ============================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...           # FULL DB access. Never put in web.
COINBASE_BASE_URL=https://api.exchange.coinbase.com

WATCHED_PAIRS=BTC-USD,ETH-USD
CANDLE_GRANULARITY=300                     # 5-min bars

POLL_INTERVAL_SECONDS=5
CANDLE_INTERVAL_SECONDS=60
INFERENCE_INTERVAL_SECONDS=30
EVALUATE_INTERVAL_MINUTES=60
REFIT_INTERVAL_HOURS=6
ROLLING_TRAIN_DAYS=30

ENABLE_PAPER_TRADING=true
ENABLE_LLM_FEATURES=false                  # feature flag for future CareerOS bridge

LOG_LEVEL=INFO
